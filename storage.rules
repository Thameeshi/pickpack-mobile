rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload and read files
    match /proofOfDelivery/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /signatures/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /odometer/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /fuel/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /receipts/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Catch-all for any other uploads by authenticated users
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }
  }
}
